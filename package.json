{
  "name": "instagram-filters",
  "version": "1.0.0",
  "description": "Advanced Instagram follower filtering and bulk selection tool with mass unfollow capabilities",
  "main": "dist/bookmarklet.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/InstagramFilters"
  },
  "keywords": [
    "instagram",
    "followers",
    "unfollowers",
    "filter",
    "bulk-operations",
    "social-media",
    "tool"
  ],
  "author": "Your Name",
  "license": "MIT",
  "engines": {
    "node": ">=16.14.0"
  },
  "scripts": {
    "build": "npm run clean && esbuild src/main.ts --bundle --minify --target=es2020 --outfile=dist/bookmarklet.js && node scripts/generate-bookmarklet.js && npm run lint",
    "build-dev": "npm run clean && esbuild src/main.ts --bundle --target=es2020 --outfile=dist/bookmarklet.js && node scripts/generate-bookmarklet.js",
    "dev": "npm run build-dev && esbuild src/main.ts --bundle --watch --target=es2020 --outfile=dist/bookmarklet.js",
    "watch": "esbuild src/main.ts --bundle --watch --outfile=dist/bookmarklet.js",
    "clean": "rimraf dist",
    "format": "prettier --write 'src/**/*.{ts,js,json}' 'scripts/**/*.js'",
    "lint": "eslint src/**/*.ts --max-warnings 5",
    "lint:fix": "eslint src/**/*.ts --fix",
    "pre-commit": "npm run lint && npm run build",
    "release": "npm run build && npm publish"
  },
  "files": [
    "dist/",
    "src/",
    "scripts/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  }
}
